AETHER_ENV=development
AETHER_CLUSTER_NAME=aether-local
AETHER_LOG_LEVEL=INFO
AETHER_REDIS_URL=redis://redis:6379/0
AETHER_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
AETHER_NEO4J_URI=neo4j://neo4j:7687
AETHER_NEO4J_USER=neo4j
AETHER_NEO4J_PASSWORD=password
AETHER_POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/aether
AETHER_TIMESCALE_DSN=postgresql://postgres:postgres@timescaledb:5432/aether_metrics
AETHER_VAULT_ADDR=http://vault:8200
AETHER_OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
AETHER_API_TOKEN=change-me
AETHER_REASONING_TRIGGER_THRESHOLD=0.8
AETHER_EVENT_BUS_BACKEND=redis_streams
AETHER_EVENT_BUS_TOPIC_PREFIX=aether
AETHER_EVENT_BUS_POLL_INTERVAL_MS=500
AETHER_STARTUP_RETRY_ATTEMPTS=20
AETHER_STARTUP_RETRY_DELAY_SECONDS=1.0
AETHER_INGESTION_SERVICE_URL=http://ingestion:8001
AETHER_FUSION_SERVICE_URL=http://fusion:8002
AETHER_MEMORY_SERVICE_URL=http://memory:8003
AETHER_REASONING_SERVICE_URL=http://reasoning:8004
AETHER_GOVERNANCE_SERVICE_URL=http://governance:8005
AETHER_ACTION_SERVICE_URL=http://action:8006
AETHER_REALTIME_SERVICE_URL=http://realtime:8007
AETHER_KERNEL_SERVICE_URL=http://kernel:8008
